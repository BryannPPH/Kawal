API_PORT=3001

# Data source:
# - sqlite keeps the local Bun SQLite database for offline demo.
# - supabase makes the Bun API fetch dashboard data from Supabase REST.
DATA_SOURCE=sqlite
# Default seed starts with zero tasks. Set true only when you want demo task rows.
SEED_DEMO_TASKS=false

# Supabase server-side credentials. Keep the service role key only in backend env.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SCHEMA=public
# workforce = app tables from docs/supabase-schema.sql.
# iot = read your current IoT tables: environment_condition, work_hours, warning, inactivity_log, rest_break.
SUPABASE_DATA_MODEL=iot

# Optional frontend public keys if you later decide to fetch directly from React.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=

# Worker PPE camera verification:
# - demo passes checks locally for hackathon flow.
# - openai sends captured camera frames to OpenAI vision.
PPE_CHECK_PROVIDER=demo
OPENAI_API_KEY=
OPENAI_PPE_MODEL=gpt-5

MQTT_BROKER_URL=mqtts://broker.example.com:8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=garudie-backend-local
MQTT_PROTOCOL_VERSION=5
MQTT_DEFAULT_QOS=1
MQTT_COMMAND_ACK_TIMEOUT_MS=5000
MQTT_COMMAND_RESULT_TIMEOUT_MS=15000
MQTT_HEARTBEAT_TIMEOUT_MS=90000
MQTT_TOPIC_PREFIX=construction/v1

API_BASE_URL=http://127.0.0.1:3001
SIM_DEVICE_ID=device-001
SIM_WORKER_ID=budi
SIM_SITE_ID=site-001
SIM_ZONE_ID=Zone C
SIM_TASK_ID=steel-beam-install
